import { Button, Slider } from "std-widgets.slint";

export component MainWindow inherits Window {
    in-out property <int> current_water: 0;
    in property <int> goal_water: 2000;
    in property <string> quote: "INIT_HYDRATION_PROTOCOL...";
    in property <string> last_event: "SYSTEM: STANDBY";
    in-out property <int> interval_minutes: 60;

    callback add_water(int);
    callback reset_data();
    callback update_interval(int);

    title: "WaterReminder Pro";
    background: #050505;
    min-width: 320px;
    min-height: 560px;

    VerticalLayout {
        padding: 24px;
        spacing: 20px;

        // 顶部黑客风标题与图标
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "[ WATER_OS_V1.0 ]";
                font-size: 14px;
                color: #00FF00;
                font-family: "monospace";
                vertical-alignment: center;
            }
            
            // 手绘风格的荧光绿“水杯”图标
            Rectangle {
                width: 30px;
                height: 30px;
                Rectangle {
                    x: 5px; y: 5px;
                    width: 15px; height: 20px;
                    border-width: 2px;
                    border-color: #00FF00;
                    border-bottom-left-radius: 4px;
                    border-bottom-right-radius: 4px;
                    Rectangle {
                        x: 2px;
                        y: parent.height - self.height - 2px;
                        width: parent.width - 4px;
                        height: (parent.height - 4px) * Math.min(1.0, current_water / goal_water);
                        background: #00FF00;
                        opacity: 0.6;
                    }
                }
                Path {
                    x: 20px; y: 8px;
                    width: 8px; height: 12px;
                    stroke: #00FF00;
                    stroke-width: 2px;
                    commands: "M 0 0 C 8 0 8 12 0 12";
                }
            }
        }

        Rectangle {
            height: 120px;
            border-width: 1px;
            border-color: #004400;
            background: #001100;
            Text {
                text: Math.round((current_water / goal_water) * 100) + "%";
                font-size: 64px;
                color: #00FF00;
                font-family: "monospace";
                font-weight: 900;
            }
        }

        HorizontalLayout {
            height: 20px;
            spacing: 4px;
            for i in 20 : Rectangle {
                background: (i / 20.0 < (current_water / goal_water)) ? #00FF00 : #002200;
                border-radius: 2px;
            }
        }

        Text {
            text: "STORAGE: " + current_water + " / " + goal_water + " ML";
            color: #00FF00;
            font-family: "monospace";
            horizontal-alignment: center;
        }

        Rectangle {
            height: 100px;
            border-width: 1px;
            border-color: #004400;
            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                Text { text: "REMINDER_FREQ: " + interval_minutes + " SEC"; color: #00FF00; font-family: "monospace"; }
                HorizontalLayout {
                    spacing: 8px;
                    // 显式将 30 传入作为 int
                    Button { text: "[30S]"; clicked => { root.interval_minutes = 30; root.update_interval(30); } }
                    Button { text: "[60S]"; clicked => { root.interval_minutes = 60; root.update_interval(60); } }
                    Button { text: "[120S]"; clicked => { root.interval_minutes = 120; root.update_interval(120); } }
                }
            }
        }

        HorizontalLayout {
            height: 50px;
            spacing: 12px;
            Button { text: "++ INTAKE_250ML"; clicked => { root.add_water(250) } }
            Button { text: "++ INTAKE_500ML"; clicked => { root.add_water(500) } }
        }

        Rectangle {
            vertical-stretch: 1;
            background: #000000;
            border-width: 1px;
            border-color: #004400;
            VerticalLayout {
                padding: 10px;
                Text {
                    text: "> " + last_event + "\n> " + quote;
                    color: #00CC00;
                    font-size: 12px;
                    font-family: "monospace";
                    wrap: word-wrap;
                }
            }
        }

        Button {
            text: "[ RESET_CORE_DATA ]";
            clicked => { root.reset_data() }
        }
    }
}
